{
  "name": "polyocr-shell",
  "version": "0.1.0",
  "description": "Electron desktop UI for the polyocr package",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.main.json",
    "build:installer": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "polyocr": "*",
    "better-sqlite3": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
